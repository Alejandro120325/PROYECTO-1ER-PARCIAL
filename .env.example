# ============================================================
# EXPLORADOR SOLAR - Variables de entorno
# Copia este archivo a .env y rellena los valores reales
# ============================================================

# ---------- SERVIDOR EXPRESS ----------
# Puerto local. Railway inyecta su propio PORT en producción.
PORT=3000
NODE_ENV=development

# ---------- BASE DE DATOS (Supabase Postgres) ----------
# Obtén el connection string desde:
#   Supabase Dashboard → Project Settings → Database → Connection string → URI
# Recomendado: usa el "Transaction pooler" (puerto 6543) para serverless / Railway.
# Formato: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://usuario:password@host:6543/postgres

# ---------- AUTENTICACIÓN JWT ----------
# Cadena LARGA y aleatoria. Genera una con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_cadena_larga_y_aleatoria
JWT_EXPIRES_IN=7d

# ---------- CORS ----------
# Orígenes permitidos para llamar al API, separados por coma.
# En desarrollo: http://localhost:3000
# En producción añade tu dominio de Vercel: https://tu-app.vercel.app
CORS_ORIGIN=http://localhost:3000

# ---------- FRONTEND ----------
# Solo si decides separar frontend (Vercel) y backend (Railway).
# El frontend usa este valor desde una <meta name="api-url"> en index.html.
# Déjalo vacío si frontend y backend están en el mismo dominio.
PUBLIC_API_URL=
